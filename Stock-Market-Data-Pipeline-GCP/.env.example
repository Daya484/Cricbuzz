# ============================================================
# Environment Variables - Stock Market Data Pipeline
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# Pipeline Environment: dv (dev) | qa (QA) | pd (prod)
ENV=dv

# Alpha Vantage API Key (get free key at https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# GCP Project ID (should match your environment)
GCP_PROJECT_ID=your-gcp-project-id-dev

# Path to GCP service account key JSON (for local development)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# GCP Region
GCP_REGION=us-central1
